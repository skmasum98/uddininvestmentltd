---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Cookie Policy | Uddin Investment Ltd">
  
  

  <!-- Cookie Content -->
  <section class="py-20 bg-white px-6">
    <div class="max-w-4xl mx-auto">
      <div class="mb-12 border-b-2 border-slate-100 pb-8 text-center md:text-left">
        <h1 class="text-4xl md:text-5xl font-black text-slate-900 mb-4 italic decoration-blue-600 underline underline-offset-8 uppercase tracking-tighter">Cookie <span class="text-blue-600">Policy</span></h1>
        <p class="text-slate-500 font-bold uppercase tracking-widest text-sm italic">Last Updated: March 2026</p>
      </div>

      <div class="space-y-12 text-slate-700 leading-relaxed italic font-medium">
        
        <!-- Section 1 -->
        <section>
          <h2 class="text-2xl font-bold text-slate-900 mb-6 italic border-l-4 border-blue-600 pl-4 uppercase tracking-tight">1. What are Cookies?</h2>
          <p>
            Cookies are small text files that are stored on your computer or mobile device when you visit our website. They are widely used by professional service providers like Uddin Investment Ltd to make websites work more efficiently and provide information to the owners of the site.
          </p>
        </section>

        <!-- Section 2 -->
        <section>
          <h2 class="text-2xl font-bold text-slate-900 mb-6 italic border-l-4 border-blue-600 pl-4 uppercase tracking-tight">2. How We Use Cookies</h2>
          <p>We use cookies to improve your experience on our website by:</p>
          <ul class="list-disc pl-8 space-y-3 mt-4">
            <li>Keeping the website secure and preventing fraud.</li>
            <li>Remembering your preferences and settings during your visit.</li>
            <li>Analyzing how you interact with our content so we can optimize our property management services.</li>
            <li>Ensuring that our contact forms and valuation requests function correctly.</li>
          </ul>
        </section>

        <!-- Section 3 -->
        <section>
          <h2 class="text-2xl font-bold text-slate-900 mb-6 italic border-l-4 border-blue-600 pl-4 uppercase tracking-tight">3. Types of Cookies We Use</h2>
          <div class="space-y-6 mt-6">
            <div class="bg-slate-50 p-6 rounded-2xl border border-slate-100 italic">
              <h3 class="font-bold text-slate-900 mb-2 underline decoration-blue-500 underline-offset-4">Essential Cookies</h3>
              <p class="text-sm">These are necessary for the website to function. They allow you to move around the site and use its features, such as our secure valuation forms.</p>
            </div>
            <div class="bg-slate-50 p-6 rounded-2xl border border-slate-100 italic">
              <h3 class="font-bold text-slate-900 mb-2 underline decoration-blue-500 underline-offset-4">Performance & Analytics</h3>
              <p class="text-sm">These help us understand how visitors use our site, which areas are most popular, and identify any errors. This data is typically anonymized.</p>
            </div>
            <div class="bg-slate-50 p-6 rounded-2xl border border-slate-100 italic">
              <h3 class="font-bold text-slate-900 mb-2 underline decoration-blue-500 underline-offset-4">Marketing Cookies</h3>
              <p class="text-sm">These may be used to track visitors across websites to deliver more relevant advertisements related to property investment and management.</p>
            </div>
          </div>
        </section>

        <!-- Section 4 -->
        <section>
          <h2 class="text-2xl font-bold text-slate-900 mb-6 italic border-l-4 border-blue-600 pl-4 uppercase tracking-tight">4. Controlling Cookies</h2>
          <p>
            Most web browsers allow you to control cookies through their settings. You can set your browser to block cookies or delete them entirely. However, please note that disabling certain cookies may impact the functionality of our website.
          </p>
          <p class="mt-4">
            To find out more about how to manage and delete cookies, visit <a href="https://www.aboutcookies.org" class="text-blue-600 font-bold underline" target="_blank">aboutcookies.org</a>.
          </p>
        </section>

        <!-- Section 5 -->
        <section class="bg-slate-900 text-white p-10 rounded-[40px] shadow-2xl relative overflow-hidden">
          <h2 class="text-xl font-bold mb-4 italic underline decoration-blue-500 underline-offset-4">Questions?</h2>
          <p class="text-slate-300 text-sm italic mb-6">If you have any questions about our use of cookies, please contact our team:</p>
          <div class="text-sm font-bold space-y-2 italic uppercase tracking-widest">
            <p>UDDIN INVESTMENT LTD</p>
            <p class="text-blue-400">info@uddininvestmentltd.com</p>
            <p>5 Elm Lawn Close, Uxbridge, UB8 1NX</p>
          </div>
          <!-- Abstract Background Element -->
          <div class="absolute -bottom-10 -right-10 w-32 h-32 bg-blue-600/20 rounded-full blur-2xl"></div>
        </section>

      </div>
    </div>
  </section>

</Layout>

<style>
  /* Ensure smooth italic rendering across all browsers */
  html { font-family: 'Inter', sans-serif; }
  p { margin-bottom: 1rem; }
</style>