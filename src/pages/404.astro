---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Page Not Found | Uddin Investment Ltd">
  

  <!-- 404 Content -->
  <section class="min-h-[70vh] flex items-center justify-center bg-white px-6 py-24 overflow-hidden relative">
    
    <!-- Decorative background element -->
    

    <div class="max-w-2xl w-full text-center relative z-10">
      <div class="mb-8 inline-block p-4 bg-blue-50 rounded-3xl border border-blue-100">
        <!-- <svg class="h-16 w-16 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
        </svg> -->
        <h2 class="text-6xl font-extrabold text-blue-600">404</h2>
      </div>

      <h1 class="text-4xl md:text-6xl font-black text-slate-900 mb-6 italic underline decoration-blue-600 underline-offset-8">Lost your <span class="text-blue-600">way home?</span></h1>
      
      <p class="text-xl text-slate-500 mb-12 italic font-medium leading-relaxed">
        The property or page you are looking for doesn't exist. <br class="hidden md:block"/>
        But don't worry, we can still help you secure your rental income.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="px-10 py-5 bg-blue-600 text-white rounded-2xl font-black text-lg hover:bg-blue-700 transition-all shadow-xl shadow-blue-200 active:scale-95">
          Return to Homepage
        </a>
        <a href="/services" class="px-10 py-5 bg-slate-900 text-white rounded-2xl font-black text-lg hover:bg-slate-800 transition-all shadow-xl shadow-slate-200 active:scale-95">
          Explore Services
        </a>
      </div>

      <div class="mt-16 pt-8 border-t border-slate-100 italic">
        <p class="text-sm text-slate-400 font-bold uppercase tracking-widest">Need immediate help?</p>
        <a href="mailto:info@uddininvestmentltd.com" class="text-blue-600 font-black hover:underline underline-offset-4">info@uddininvestmentltd.com</a>
      </div>
    </div>

    <!-- Background Decoration -->
    <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-blue-600/5 rounded-full blur-3xl"></div>
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-blue-600/5 rounded-full blur-3xl"></div>
  </section>

  

</Layout>