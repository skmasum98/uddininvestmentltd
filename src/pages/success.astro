---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Thank You | Uddin Investment Ltd">
  <section class="min-h-screen flex items-center justify-center bg-white px-6">
    <div class="max-w-xl text-center">
      <div class="mb-8 inline-block p-6 bg-green-50 rounded-full text-green-600">
        <svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
      </div>
      <h1 class="text-4xl font-black text-slate-900 mb-4 italic uppercase">Message Received!</h1>
      <p class="text-lg text-slate-500 mb-10 italic">Thank you for contacting Uddin Investment Ltd. Our expert team will review your property details and get back to you within 24 hours.</p>
      <a href="/" class="px-10 py-5 bg-blue-600 text-white rounded-2xl font-black text-lg hover:bg-slate-900 transition-all inline-block">Back to Homepage</a>
    </div>
  </section>
</Layout>